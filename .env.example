# --- LLM (required on Render/Railway; optional locally if using Ollama on localhost) ---

# Provider: ollama | openai
LLM_PROVIDER=ollama

# Ollama (local or remote server with Ollama exposed)
LLM_API_URL=http://localhost:11434/api/chat
LLM_MODEL=llama3

# OpenAI-compatible (OpenAI, Groq, Together, OpenRouter, etc.)
# LLM_PROVIDER=openai
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# Optional
# LLM_TEMPERATURE=0
# LLM_MAX_WORKERS=2
# LLM_FALLBACK_ON_ERROR=true

# Frontend (Vercel) — set in Vercel dashboard, not Render
# VITE_API_BASE_URL=https://your-service.onrender.com/api

# Backend CORS (Render) — comma-separated origins, or * for all
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-*.vercel.app
